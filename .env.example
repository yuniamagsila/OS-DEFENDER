# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=OS Defender
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/os_defender

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── AI Service ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=changeme_internal_secret

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# ─── Notifications ────────────────────────────────────────────────────────────

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Crawlers ─────────────────────────────────────────────────────────────────

# SerpAPI (Google SERP)
SERPAPI_KEY=

# Bing Search API
BING_SEARCH_API_KEY=

# Twitter / X API v2
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# YouTube Data API v3
YOUTUBE_API_KEY=

# Google Places API
GOOGLE_PLACES_API_KEY=

# ─── Dark Web / Breach Intelligence ───────────────────────────────────────────

# IntelX API
INTELX_API_KEY=
INTELX_API_HOST=https://2.intelx.io

# DeHashed API
DEHASHED_API_KEY=
DEHASHED_EMAIL=

# Tor proxy (darkweb-crawler VPS)
TOR_SOCKS_PROXY=socks5://127.0.0.1:9050
TOR_CONTROL_HOST=127.0.0.1
TOR_CONTROL_PORT=9051

# ─── Storage ──────────────────────────────────────────────────────────────────
# Cloudflare R2 (evidence screenshots, PDF reports)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=os-defender-evidence
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ─── Webhook ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=changeme_webhook_hmac_secret

# ─── Monitoring / Observability ───────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
