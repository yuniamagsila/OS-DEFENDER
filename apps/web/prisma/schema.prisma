generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  CONSULTANT
  ADMIN
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TakedownStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  passwordHash     String
  role             UserRole          @default(CLIENT)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  profiles         IdentityProfile[]
  cases            Case[]
  notifications    Notification[]
}

model IdentityProfile {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  alias            String?
  profession       String?
  emails           String[]
  phones           String[]
  usernames        String[]
  domains          String[]
  nikEncrypted     String?
  industry         String?
  reputationScore  Int       @default(100)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  mentions         Mention[]
  alerts           Alert[]
  cases            Case[]
  reports          Report[]
  takedowns        Takedown[]
}

model Mention {
  id               String          @id @default(cuid())
  profileId        String
  profile          IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sourceType       String
  sourceName       String
  url              String
  content          String          @db.Text
  sentiment        String?
  riskScore        Int             @default(0)
  evidenceUrl      String?
  publishedAt      DateTime?
  crawledAt        DateTime        @default(now())
}

model Alert {
  id               String          @id @default(cuid())
  profileId        String
  profile          IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  severity         AlertSeverity
  category         String
  title            String
  summary          String          @db.Text
  evidenceJson     Json?
  isRead           Boolean         @default(false)
  createdAt        DateTime        @default(now())
}

model Case {
  id               String          @id @default(cuid())
  profileId        String
  profile          IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  clientId         String
  client           User            @relation(fields: [clientId], references: [id])
  title            String
  description      String          @db.Text
  status           CaseStatus      @default(OPEN)
  priority         CasePriority    @default(MEDIUM)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  messages         CaseMessage[]
}

model CaseMessage {
  id               String   @id @default(cuid())
  caseId           String
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  senderRole       UserRole
  senderName       String
  body             String   @db.Text
  createdAt        DateTime @default(now())
}

model Report {
  id               String          @id @default(cuid())
  profileId        String
  profile          IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title            String
  type             String
  fileUrl          String?
  generatedAt      DateTime        @default(now())
}

model Takedown {
  id               String          @id @default(cuid())
  profileId        String
  profile          IdentityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  target           String
  platform         String
  status           TakedownStatus  @default(PENDING)
  filedAt          DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Notification {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel          String
  message          String
  sentAt           DateTime @default(now())
  isRead           Boolean  @default(false)
}
